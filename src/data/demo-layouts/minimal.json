{
  "elements": [
    {
      "id": "main-container",
      "type": "container",
      "settings": {
        "className": "min-h-screen"
      },
      "components": [
        {
          "id": "nav-minimal",
          "type": "navigation",
          "settings": {
            "brandName": "Store",
            "showSearch": false,
            "links": [
              { "label": "Home", "href": "/" },
              { "label": "Products", "href": "/products" },
              { "label": "About", "href": "/about" },
              { "label": "Contact", "href": "/contact" }
            ]
          }
        },
        {
          "id": "hero-minimal",
          "type": "hero",
          "settings": {
            "title": "Minimal Store",
            "subtitle": "Simple, Clean, Beautiful",
            "buttonText": "Shop Now",
            "align": "center",
            "paddingY": 80
          }
        },
        {
          "id": "products-minimal",
          "type": "product-grid",
          "settings": {
            "title": "Featured Products",
            "columns": 3,
            "align": "center",
            "paddingY": 40
          }
        },
        {
          "id": "newsletter-minimal",
          "type": "newsletter",
          "settings": {
            "title": "Stay Updated",
            "subtitle": "Subscribe to our newsletter",
            "align": "center"
          }
        },
        {
          "id": "footer-minimal",
          "type": "footer",
          "settings": {
            "brandName": "Store",
            "links": [
              {
                "title": "Shop",
                "items": [
                  { "title": "Products", "href": "/products" }
                ]
              },
              {
                "title": "Info",
                "items": [
                  { "title": "About", "href": "/about" },
                  { "title": "Contact", "href": "/contact" }
                ]
              }
            ]
          }
        }
      ]
    }
  ]
}

{
  "elements": [
    {
      "id": "main-container",
      "type": "container",
      "settings": {
        "className": "min-h-screen"
      },
      "components": [
        {
          "id": "nav-marketplace",
          "type": "navigation",
          "settings": {
            "brandName": "Marketplace",
            "showSearch": false,
            "links": [
              { "label": "Home", "href": "/" },
              { "label": "Products", "href": "/products" },
              { "label": "About", "href": "/about" },
              { "label": "Contact", "href": "/contact" }
            ]
          }
        },
        {
          "id": "hero-marketplace",
          "type": "hero",
          "settings": {
            "title": "Discover Amazing Products",
            "subtitle": "From thousands of vendors worldwide",
            "buttonText": "Start Shopping",
            "align": "center",
            "paddingY": 60
          }
        },
        {
          "id": "products-marketplace",
          "type": "product-grid",
          "settings": {
            "title": "Trending Now",
            "columns": 4,
            "align": "left",
            "paddingY": 50
          }
        },
        {
          "id": "collections-marketplace",
          "type": "collections",
          "settings": {
            "title": "Popular Categories",
            "columns": 3,
            "align": "center",
            "paddingY": 50
          }
        },
        {
          "id": "footer-marketplace",
          "type": "footer",
          "settings": {
            "brandName": "Marketplace",
            "links": [
              {
                "title": "Shop",
                "items": [
                  { "title": "Products", "href": "/products" }
                ]
              },
              {
                "title": "Info",
                "items": [
                  { "title": "About", "href": "/about" },
                  { "title": "Contact", "href": "/contact" }
                ]
              }
            ]
          }
        }
      ]
    }
  ]
}
